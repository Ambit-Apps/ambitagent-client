# Copy to .env for local dev. .env is gitignored.

# Base URL of the admin control plane. http/https is automatically
# translated to ws/wss for the WebSocket connection.
ADMIN_URL=http://localhost:3100

# Raw enrollment token from `POST /rest/runtimes/enroll` on the admin.
# Shown once by that endpoint — copy immediately, it can't be re-read.
ENROLLMENT_TOKEN=paste-your-enrollment-token-here

# ── Managed Chrome ────────────────────────────────────────────────────
# The daemon launches and monitors a dedicated Chrome for browser-type
# agents that use `browser.model: "attached_chrome"` in their manifest.
# It has its own profile (~/.ambit/chrome-profile), its own debug port
# (9222), and never touches your personal Chrome. Extensions + logins you
# do in that window persist across daemon restarts.
#
# Uncomment on truly headless server VMs that only run api-type agents.
# AMBIT_CHROME_ENABLED=false

# Advanced overrides. Rarely needed — the daemon auto-detects Chrome per OS.
# AMBIT_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# AMBIT_CHROME_PORT=9222
# AMBIT_CHROME_PROFILE_DIR=/absolute/path/to/dir

# Legacy override: point the runtime at an already-running debug Chrome
# instead of the daemon-managed one. Useful during dev when you want to
# attach to a Chrome you launched yourself. Wins over daemon-managed.
# AMBIT_ATTACH_CDP=http://localhost:9222

# Optional: general daemon overrides
# LOG_LEVEL=info                   # debug | info | warn | error
# HEARTBEAT_INTERVAL_MS=15000
# RECONNECT_MIN_DELAY_MS=1000
# RECONNECT_MAX_DELAY_MS=30000
