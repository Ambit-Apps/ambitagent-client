# Copy to .env for local dev. .env is gitignored.

# Base URL of the admin control plane. http/https is automatically
# translated to ws/wss for the WebSocket connection.
ADMIN_URL=http://localhost:3100

# Raw enrollment token from `POST /rest/runtimes/enroll` on the admin.
# Shown once by that endpoint — copy immediately, it can't be re-read.
ENROLLMENT_TOKEN=paste-your-enrollment-token-here

# Optional: overrides
# LOG_LEVEL=info                   # debug | info | warn | error
# HEARTBEAT_INTERVAL_MS=15000
# RECONNECT_MIN_DELAY_MS=1000
# RECONNECT_MAX_DELAY_MS=30000
